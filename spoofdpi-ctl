#!/usr/bin/env bash
# spoofdpi-ctl — SpoofDPI servis yönetim aracı

set -euo pipefail

LABEL="com.spoofdpi"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
BIN_DIR="/opt/homebrew/bin"

# PAC dosyası yolu
PAC_FILE="$BIN_DIR/discord-proxy.pac"
PAC_URL="file://$PAC_FILE"

# Log dizinini dinamik bul
if [[ -d "/opt/homebrew/var/log/spoofdpi" ]]; then
    LOG_OUT="/opt/homebrew/var/log/spoofdpi/spoofdpi.log"
    LOG_ERR="/opt/homebrew/var/log/spoofdpi/spoofdpi.error.log"
else
    LOG_OUT="/usr/local/var/log/spoofdpi/spoofdpi.log"
    LOG_ERR="/usr/local/var/log/spoofdpi/spoofdpi.error.log"
fi

# ── Renkler ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

ok()   { echo -e "${GREEN}✓${RESET} $*"; }
err()  { echo -e "${RED}✗${RESET} $*" >&2; }
info() { echo -e "${CYAN}→${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }

# ── Yardımcılar ────────────────────────────────────────────────────────────────
is_loaded() {
    launchctl list "$LABEL" &>/dev/null
}

is_running() {
    local pid
    pid=$(launchctl list "$LABEL" 2>/dev/null | grep '"PID"' | grep -oE '[0-9]+')
    [[ "$pid" =~ ^[0-9]+$ ]]
}

get_pid() {
    launchctl list "$LABEL" 2>/dev/null | grep '"PID"' | grep -oE '[0-9]+'
}

check_plist() {
    if [[ ! -f "$PLIST" ]]; then
        err "Plist bulunamadı: $PLIST"
        exit 1
    fi
}

# ── PAC Proxy Yönetimi ────────────────────────────────────────────────────────
get_active_services() {
    # Aktif ağ servislerini bul (Wi-Fi, Ethernet vb.)
    networksetup -listallnetworkservices 2>/dev/null | tail -n +2 | while read -r svc; do
        # Devre dışı servisleri (* ile başlar) atla
        [[ "$svc" == \** ]] && continue
        echo "$svc"
    done
}

set_pac_proxy() {
    if [[ ! -f "$PAC_FILE" ]]; then
        err "PAC dosyası bulunamadı: $PAC_FILE"
        return 1
    fi
    local count=0
    while IFS= read -r svc; do
        networksetup -setautoproxyurl "$svc" "$PAC_URL" 2>/dev/null && ((count++)) || true
    done < <(get_active_services)
    if (( count > 0 )); then
        ok "PAC proxy ayarlandı (sadece Discord trafiği) — $count ağ servisi"
    else
        warn "PAC proxy ayarlanamadı — aktif ağ servisi bulunamadı"
    fi
}

clear_pac_proxy() {
    local count=0
    while IFS= read -r svc; do
        networksetup -setautoproxystate "$svc" off 2>/dev/null && ((count++)) || true
    done < <(get_active_services)
    if (( count > 0 )); then
        ok "PAC proxy kaldırıldı — $count ağ servisi"
    fi
}

# ── Komutlar ───────────────────────────────────────────────────────────────────
cmd_start() {
    check_plist
    if is_running; then
        warn "SpoofDPI zaten çalışıyor (PID: $(get_pid))"
        return
    fi
    if ! is_loaded; then
        launchctl load "$PLIST"
    fi
    # macOS Ventura+ launchctl start yerine kickstart kullanır
    if launchctl kickstart -k "gui/$(id -u)/$LABEL" &>/dev/null 2>&1; then
        true
    else
        launchctl start "$LABEL" 2>/dev/null || true
    fi
    sleep 0.5
    if is_running; then
        ok "SpoofDPI başlatıldı (PID: $(get_pid))"
        set_pac_proxy
    else
        err "Başlatılamadı. Log kontrol et: spoofdpi-ctl log"
        exit 1
    fi
}

cmd_stop() {
    # Önce PAC proxy'yi kaldır
    clear_pac_proxy

    if ! is_loaded; then
        warn "SpoofDPI zaten durmuş"
        return
    fi
    # macOS Ventura+ kickstart/bootout tercih eder
    if launchctl kill TERM "gui/$(id -u)/$LABEL" &>/dev/null 2>&1; then
        true
    else
        launchctl stop "$LABEL" 2>/dev/null || true
    fi
    sleep 0.5
    if ! is_running; then
        ok "SpoofDPI durduruldu"
    else
        err "Durdurulamadı"
        exit 1
    fi
}

cmd_restart() {
    info "Yeniden başlatılıyor..."
    cmd_stop
    sleep 0.3
    cmd_start
}

cmd_status() {
    echo -e "${BOLD}SpoofDPI Servis Durumu${RESET}"
    echo "──────────────────────────────"
    if is_running; then
        local pid
        pid=$(get_pid)
        echo -e "Durum  : ${GREEN}● Çalışıyor${RESET}"
        echo -e "PID    : ${CYAN}$pid${RESET}"
        # Proxy port
        local port
        port=$(ps aux | grep '[s]poofdpi' | grep -oE '\-port [0-9]+' | awk '{print $2}')
        [[ -n "$port" ]] && echo -e "Port   : ${CYAN}$port${RESET}" || echo -e "Port   : ${CYAN}8080${RESET} (varsayılan)"
        echo -e "Mod    : ${CYAN}Sadece Discord${RESET} (PAC proxy)"
    else
        echo -e "Durum  : ${RED}● Durmuş${RESET}"
    fi
    echo -e "PAC    : $PAC_FILE"
    echo -e "Plist  : $PLIST"
    echo -e "Log    : $LOG_OUT"
    echo "──────────────────────────────"
}

cmd_log() {
    local lines="${1:-50}"
    if [[ ! -f "$LOG_OUT" ]]; then
        warn "Log dosyası henüz oluşturulmadı"
        return
    fi
    echo -e "${BOLD}Son $lines satır (stdout):${RESET}"
    tail -n "$lines" "$LOG_OUT"
    if [[ -f "$LOG_ERR" ]] && [[ -s "$LOG_ERR" ]]; then
        echo ""
        echo -e "${BOLD}Son $lines satır (stderr):${RESET}"
        tail -n "$lines" "$LOG_ERR"
    fi
}

cmd_log_follow() {
    info "Log takip ediliyor (çıkmak için Ctrl+C)..."
    tail -f "$LOG_OUT" &
    TAIL_PID=$!
    trap "kill $TAIL_PID 2>/dev/null" EXIT
    wait
}

cmd_enable() {
    check_plist
    # Plist'teki RunAtLoad'u true yap
    /usr/libexec/PlistBuddy -c "Set :RunAtLoad true" "$PLIST"
    if ! is_loaded; then
        launchctl load "$PLIST"
    else
        launchctl unload "$PLIST"
        launchctl load "$PLIST"
    fi
    ok "Otomatik başlatma aktif — login olduğunda otomatik başlayacak"
}

cmd_disable() {
    check_plist
    /usr/libexec/PlistBuddy -c "Set :RunAtLoad false" "$PLIST"
    if is_loaded; then
        launchctl unload "$PLIST"
        launchctl load "$PLIST"
    fi
    ok "Otomatik başlatma devre dışı"
}

cmd_help() {
    echo -e "${BOLD}spoofdpi-ctl${RESET} — SpoofDPI servis yönetim aracı"
    echo ""
    echo -e "${BOLD}Kullanım:${RESET}"
    echo -e "  spoofdpi-ctl ${CYAN}start${RESET}           Servisi başlat (sadece Discord proxy)"
    echo -e "  spoofdpi-ctl ${CYAN}stop${RESET}            Servisi durdur (proxy ayarlarını temizle)"
    echo -e "  spoofdpi-ctl ${CYAN}restart${RESET}         Servisi yeniden başlat"
    echo -e "  spoofdpi-ctl ${CYAN}status${RESET}          Servis durumunu göster"
    echo -e "  spoofdpi-ctl ${CYAN}log${RESET} [n]         Son n satır logu göster (varsayılan: 50)"
    echo -e "  spoofdpi-ctl ${CYAN}log -f${RESET}          Logu canlı takip et"
    echo -e "  spoofdpi-ctl ${CYAN}enable${RESET}          Login'de otomatik başlatmayı aç"
    echo -e "  spoofdpi-ctl ${CYAN}disable${RESET}         Login'de otomatik başlatmayı kapat"
    echo ""
    echo -e "${BOLD}Not:${RESET} Sadece Discord trafiği proxy'den geçer (PAC dosyası)."
    echo ""
}

# ── Ana giriş ──────────────────────────────────────────────────────────────────
case "${1:-help}" in
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    log)
        if [[ "${2:-}" == "-f" ]]; then
            cmd_log_follow
        else
            cmd_log "${2:-50}"
        fi
        ;;
    enable)   cmd_enable ;;
    disable)  cmd_disable ;;
    help|--help|-h) cmd_help ;;
    *)
        err "Bilinmeyen komut: $1"
        cmd_help
        exit 1
        ;;
esac
